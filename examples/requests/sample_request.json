      "audioUrl": "https://qihui-duomo.oss-cn-beijing.aliyuncs.com/audio/db4175a2-1e04-4814-aede-998fb68241c6-另一个.wav",
      "sentences": [
        {
          "index": 1,
          "text": "另一个例题：证明f(x)=2x+1是增函数。",
          "startSec": 0,
          "endSec": 5.242
        },
        {
          "index": 2,
          "text": "标准步骤是：取值、作差、定号、下结论。",
          "startSec": 5.242,
          "endSec": 9.254
        }
      ],
      "subtitleItems": [
        {
          "index": 1,
          "text": "另一个例题：证明f(x)=2x+1是增函数。",
          "startSec": 0,
          "endSec": 5.242
        },
        {
          "index": 2,
          "text": "标准步骤是：取值、作差、定号、下结论。",
          "startSec": 5.242,
          "endSec": 9.254
        }
      ],
      "sceneSpec": {
        "layoutTemplate": "process_flow",
        "objects": [
          {
            "id": "OBJ1001",
            "type": "text",
            "content": "证明：f(x)=2x+1 是增函数。",
            "role": "例题标题",
            "placement": "top",
            "style": {
              "scale": 0.8,
              "emphasis": "high"
            }
          },
          {
            "id": "OBJ1002",
            "type": "text",
            "content": "1. 取值\n2. 作差\n3. 定号\n4. 下结论",
            "role": "证明步骤标题",
            "placement": "left",
            "style": {
              "scale": 0.8,
              "emphasis": "medium"
            }
          },
          {
            "id": "OBJ1003",
            "type": "formula",
            "content": "设 x₁, x₂ ∈ R, 且 x₁ < x₂",
            "role": "步骤1内容（取值）",
            "placement": "right",
            "style": {
              "scale": 0.7,
              "emphasis": "medium"
            }
          },
          {
            "id": "OBJ1004",
            "type": "formula",
            "content": "f(x₁)-f(x₂) = (2x₁+1)-(2x₂+1) = 2(x₁-x₂)",
            "role": "步骤2&3内容（作差、变形）",
            "placement": "right",
            "style": {
              "scale": 0.7,
              "emphasis": "medium"
            }
          },
          {
            "id": "OBJ1005",
            "type": "formula",
            "content": "∵ x₁ < x₂, ∴ x₁-x₂ < 0, ∴ f(x₁)-f(x₂) < 0",
            "role": "步骤3内容（定号）",
            "placement": "right",
            "style": {
              "scale": 0.7,
              "emphasis": "medium"
            }
          },
          {
            "id": "OBJ1006",
            "type": "formula",
            "content": "∴ f(x₁) < f(x₂)。\n故 f(x)=2x+1 在 R 上是增函数。",
            "role": "步骤4内容（结论）",
            "placement": "right",
            "style": {
              "scale": 0.7,
              "emphasis": "high"
            }
          }
        ]
      },
