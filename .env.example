# ============================================
# 应用基础配置
# ============================================
APP_NAME=Manim Video API Service  # 应用名称，用于日志和监控标识
APP_ENV=dev                        # 运行环境：dev(开发) / staging(预发布) / prod(生产)
HOST=0.0.0.0                       # 服务监听地址，0.0.0.0 表示允许外部访问
PORT=8000                          # 服务监听端口
LOG_LEVEL=INFO                     # 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_TO_FILE=false                  # 是否将日志输出到文件 (logs/app.log)
USE_JSON_LOG=false                 # 是否使用 JSON 格式输出日志（生产环境推荐 true）

# ============================================
# 运行时配置
# ============================================
RUNTIME_ROOT=runtime/tasks         # 任务运行时根目录，存储所有任务的执行文件、日志和产物
PROMPT_ROOT=prompts                # Prompt 模板根目录，存放各 Agent 的系统提示词
MAX_ATTEMPTS=6                     # 最大重试次数，当渲染失败时的自动修复尝试上限

# ============================================
# LLM (大语言模型) 配置
# ============================================
ENABLE_LLM_ASSIST=false            # 是否启用 LLM 辅助功能（代码生成、错误诊断等）
LLM_PROVIDER=mock                  # LLM 提供商：mock(模拟) / deepseek / openai / azure / custom
LLM_BASE_URL=                      # LLM API 基础 URL（OpenAI 兼容接口），例如：https://api.deepseek.com/v1 或 https://api.openai.com/v1
LLM_API_KEY=                       # LLM API 密钥
LLM_MODEL=                         # LLM 模型名称：deepseek-v4-pro / deepseek-v4-flash / gpt-4 等

# DeepSeek 思考模式配置（v4-pro 默认启用，v4-flash 可选启用）
DEEPSEEK_ENABLE_THINKING=true      # 是否启用思考模式
DEEPSEEK_REASONING_EFFORT=high     # 思考强度：high / max

# ============================================
# 智能体模型配置（可选，未配置则使用默认 LLM_MODEL）
# ============================================
PLANNER_MODEL=                     # RequestPlanner 使用的模型（建议：deepseek-v4-pro）
PLANNER_ENABLE_THINKING=true       # RequestPlanner 是否启用思考模式
CODE_EXPERT_MODEL=                 # ManimCodeExpert/DirectCodegenAgent 使用的模型（建议：deepseek-v4-pro）
CODE_EXPERT_ENABLE_THINKING=true   # ManimCodeExpert 是否启用思考模式
DIAGNOSER_MODEL=                   # ErrorDiagnoser 使用的模型（建议：deepseek-v4-flash）
REPAIR_MODEL=                      # RepairAgent 使用的模型（建议：deepseek-v4-pro）
REPAIR_ENABLE_THINKING=true        # RepairAgent 是否启用思考模式
SUMMARIZER_MODEL=                  # NoticeSummarizer 使用的模型（建议：deepseek-v4-flash）
REDLINES_MODEL=                    # NoticeRedlines 使用的模型（建议：deepseek-v4-flash）

# ============================================
# OSS (对象存储服务) 配置 - 阿里云 OSS
# ============================================
OSS_ENABLED=false                  # 是否启用 OSS 上传功能
OSS_ENDPOINT=                      # OSS 服务端点，例如：oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=                        # OSS Bucket 名称
OSS_ACCESS_KEY_ID=                 # 阿里云 AccessKey ID
OSS_ACCESS_KEY_SECRET=             # 阿里云 AccessKey Secret
OSS_SECURITY_TOKEN=                # STS 临时安全令牌（可选，使用 RAM STS 时需要）
OSS_PUBLIC_BASE_URL=               # OSS 公共访问基础 URL，用于生成可公开访问的文件链接
OSS_PATH_PREFIX=videos             # OSS 存储路径前缀，文件将上传到 oss://{bucket}/{prefix}/...

# ============================================
# 外部工具路径配置
# ============================================
FFPROBE_BIN=ffprobe                # ffprobe 可执行文件路径，用于读取视频/音频元数据
MANIM_BIN=manim                    # Manim 可执行文件路径，用于渲染数学动画
